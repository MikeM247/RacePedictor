{
  "name": "racepredictor",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "racepredictor",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/web": {
      "name": "@racepredictor/web",
      "version": "0.1.0",
      "dependencies": {
        "@racepredictor/core": "^0.1.0"
      }
    },
    "node_modules/@racepredictor/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@racepredictor/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/zod": {
      "resolved": "packages/zod",
      "link": true
    },
    "packages/core": {
      "name": "@racepredictor/core",
      "version": "0.1.0",
      "dependencies": {
        "zod": "^3.23.8"
      }
    },
    "packages/zod": {
      "version": "3.23.8"
    }
  }
}
