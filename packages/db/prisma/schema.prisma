generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SourceType {
  gpx
  tcx
  csv
  fit
  strava
  garmin
  polar
  coros
  suunto
  other
}

enum SportType {
  run
  trail_run
  treadmill_run
  walk
  hike
  other
}

enum ImportStatus {
  uploaded
  parsed
  normalizing
  completed
  failed
}

enum StagingNormalizeStatus {
  pending
  normalized
  skipped
  error
}

model Import {
  id               String     @id @default(cuid())
  sourceType       SourceType
  status           ImportStatus @default(uploaded)
  idempotencyKey   String?    @unique
  stagedCount      Int        @default(0)
  normalizedCount  Int        @default(0)
  duplicateCount   Int        @default(0)
  rejectedCount    Int        @default(0)
  errorCount       Int        @default(0)
  normalizeCursor  String?
  normalizeHasMore Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  rawFiles         RawFile[]
  stagingActivities StagingActivity[]

  @@index([status, createdAt(sort: Desc)])
}

model RawFile {
  id              String   @id @default(cuid())
  importId        String
  fileName        String
  fileChecksum    String
  fileSizeBytes   Int?
  mimeType        String?
  parserSummary   String?
  metadataSummary String?
  createdAt       DateTime @default(now())
  import          Import   @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([importId, fileChecksum])
  @@index([fileChecksum])
}

model StagingActivity {
  id                   String   @id @default(cuid())
  importId             String
  athleteId            String
  sourceType           SourceType
  stagingIndex         Int
  normalizeStatus      StagingNormalizeStatus @default(pending)
  sourceActivityId     String?
  dedupeHash           String?
  occurredAt           DateTime?
  parsePayload         String?
  parseError           String?
  normalizedActivityId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  import               Import   @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([importId, stagingIndex])
  @@index([importId, normalizeStatus, stagingIndex])
  @@index([athleteId, sourceType, occurredAt(sort: Desc)])
}

model Activity {
  id                  String     @id @default(cuid())
  athleteId           String
  sourceType          SourceType
  sourceFileId        String?
  sourceActivityId    String?
  occurredAt          DateTime
  endedAt             DateTime
  elapsedTimeS        Int
  movingTimeS         Int?
  sport               SportType
  distanceM           Float
  avgPaceSecPerKm     Float
  best1kSec           Float?
  best5kSec           Float?
  elevationGainM      Float
  elevationLossM      Float
  minElevationM       Float?
  maxElevationM       Float?
  avgHrBpm            Int?
  maxHrBpm            Int?
  minHrBpm            Int?
  hrAvailable         Boolean
  avgCadenceSpm       Float?
  maxCadenceSpm       Float?
  cadenceAvailable    Boolean
  paceVariability     Float?
  hrDriftPct          Float?
  hillDifficulty      Float?
  dedupeHash          String
  createdAt           DateTime   @default(now())
  splits              ActivitySplitKm[]
  routeSignature      RouteSignature?

  @@index([athleteId, occurredAt(sort: Desc)])
  @@index([athleteId, sport, occurredAt(sort: Desc)])
  @@index([athleteId, sourceType, occurredAt(sort: Desc)])
  @@unique([athleteId, sourceType, sourceActivityId])
  @@unique([athleteId, dedupeHash])
}

model RouteSignature {
  id          String   @id @default(cuid())
  activityId  String   @unique
  athleteId   String
  startLat    Float
  startLon    Float
  endLat      Float
  endLon      Float
  bboxMinLat  Float
  bboxMinLon  Float
  bboxMaxLat  Float
  bboxMaxLon  Float
  polyline    String?
  elevProfile String?
  routeHash   String
  createdAt   DateTime @default(now())
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([athleteId, routeHash])
}

model ActivitySplitKm {
  id              String    @id @default(cuid())
  activityId      String
  athleteId       String
  splitIndex      Int
  startOffsetS    Int
  endOffsetS      Int
  durationS       Int
  distanceM       Float
  paceSecPerKm    Float
  elevGainM       Float
  elevLossM       Float
  avgHrBpm        Int?
  maxHrBpm        Int?
  avgCadenceSpm   Float?
  createdAt       DateTime  @default(now())
  activity        Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, splitIndex])
  @@index([athleteId, createdAt])
}

model WeeklyFeature {
  id                 String    @id @default(cuid())
  athleteId          String
  weekStartDate      DateTime
  weekEndDate        DateTime
  runCount           Int
  totalDistanceM     Float
  totalElapsedTimeS  Int
  totalElevationGainM Float
  longRunDistanceM   Float
  longestRunId       String?
  easyDistanceM      Float
  moderateDistanceM  Float
  hardDistanceM      Float
  avgPaceSecPerKm    Float?
  avgHrBpm           Int?
  strainScore        Float?
  monotonyScore      Float?
  consistencyScore   Float?
  dataCompleteness   Float
  createdAt          DateTime  @default(now())

  @@unique([athleteId, weekStartDate])
  @@index([athleteId, weekStartDate(sort: Desc)])
  @@index([weekStartDate(sort: Desc)])
}
